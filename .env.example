# ─────────────────────────────────────────────────────────────────────────────
# Example environment variables for docker-compose.yml AND `./mvnw quarkus:dev`
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and customize for your local setup:
#
#   cp .env.example .env
#
# IMPORTANT:
#   - `.env` is gitignored: NEVER commit real secrets.
#   - This `.env.example` IS safe to commit: only placeholders / commented vars.
#   - `.env` is read by BOTH docker-compose (variable substitution) AND Quarkus
#     when you run `./mvnw quarkus:dev`. That second part matters: any UNcommented
#     Quarkus var here affects dev mode. That's why the OIDC and Mongo connection
#     vars below are COMMENTED by default — a fresh `cp` must not disable Dev
#     Services or force OIDC.
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# Host port mappings  (docker-compose)
# ═════════════════════════════════════════════════════════════════════════════
# Change these if you have other services using the same ports locally.
# Containers always listen on their default internal ports (8080, 27017, 8081);
# only the host-side mapping changes.

SERVICE_POLICY_HOST_PORT=8080
MONGO_DB_HOST_PORT=27017
MONGO_EXPRESS_HOST_PORT=8081


# ═════════════════════════════════════════════════════════════════════════════
# Mongo Express UI authentication  (docker-compose)
# ═════════════════════════════════════════════════════════════════════════════
# Basic auth for the Mongo Express WEB UI itself (not for MongoDB). The local
# compose runs MongoDB WITHOUT access control, so no Mongo credentials are needed.

MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin


# ═════════════════════════════════════════════════════════════════════════════
# Quarkus profile  (docker-compose container + quarkus:dev)
# ═════════════════════════════════════════════════════════════════════════════
# dev   → Swagger UI enabled, verbose logs, Dev Services, OIDC disabled by default.
# test  → reduced logging, used by the test suite.
# prod  → packaged-jar behavior, Swagger UI off, JSON logs, connection-string required.

QUARKUS_PROFILE=dev

# Optional:
# QUARKUS_LOG_LEVEL=DEBUG


# ═════════════════════════════════════════════════════════════════════════════
# MongoDB connection  (deploy / IDE-against-compose)  — COMMENTED ON PURPOSE
# ═════════════════════════════════════════════════════════════════════════════
# Standalone Mongo is enough: activation is a single-document update on the policy
# head (ADR-016), so no replica set is required.
#
# Leave this COMMENTED for normal `quarkus:dev`: absence = Quarkus Dev Services
# starts a throwaway MongoDB.
#
# Uncomment ONLY if you want dev/IDE to hit the compose MongoDB (the same one
# Mongo Express sees) instead of Dev Services.
#   - app running inside the compose network:   host = mongodb
#   - app running on your host (jar/IDE):        host = localhost:${MONGO_DB_HOST_PORT}
#
# QUARKUS_MONGODB_CONNECTION_STRING=mongodb://mongodb:27017
#
# Deploy (remote MongoDB on another host/VM), with auth:
# QUARKUS_MONGODB_CONNECTION_STRING=mongodb://<user>:<password>@<mongo-host>:27017/?authSource=admin


# ═════════════════════════════════════════════════════════════════════════════
# Keycloak 26 / OIDC  (bearer-only resource server, ADR-013)  — COMMENTED
# ═════════════════════════════════════════════════════════════════════════════
# The PDP validates signed JWTs against the realm's JWKS — NO client secret here.
# OIDC is disabled by default in the dev/test profiles. To exercise the R013
# security base (admin gate, 401/403) locally against Keycloak 26, uncomment:
#
# QUARKUS_OIDC_ENABLED=true
# QUARKUS_OIDC_AUTH_SERVER_URL=https://<keycloak-host>/realms/<realm>
# QUARKUS_OIDC_CLIENT_ID=service-policy
#
# Audience validation. Keycloak does NOT emit the resource-server client-id in
# `aud` unless you add an "Audience" protocol mapper on the client. If every
# request 401s right after enabling OIDC, that mapper is the usual cause. To try
# without audience checks first, you can leave this commented and also comment
# `token.audience` in application.yml.
# QUARKUS_OIDC_TOKEN_AUDIENCE=service-policy
#
# Authorization markers (ADR-013). Defaults are authz-admin / pdp-client; override
# if your realm uses different role names.
# SERVICE_POLICY_AUTHZ_ADMIN_ROLE=authz-admin
# SERVICE_POLICY_AUTHZ_DELEGATION_ROLE=pdp-client
#
# TLS / internal CA: if Keycloak runs behind a private/internal CA, make the JVM
# trust that CA. Prefer trusting it at the JVM / container truststore level over
# per-app Quarkus TLS config.
#   e.g. mount the CA and run with:
#     -Djavax.net.ssl.trustStore=/etc/pki/service-policy-truststore.p12
#     -Djavax.net.ssl.trustStorePassword=<pwd>
#   or import the CA into the container base image's cacerts at build time.


# ═════════════════════════════════════════════════════════════════════════════
# MongoDB root credentials  (ONLY for the authenticated Mongo variant)
# ═════════════════════════════════════════════════════════════════════════════
# NOT used by the default local compose (which runs Mongo without access control).
# Kept here for when you mirror an authenticated Mongo locally.
# MONGO_ROOT_USER=root
# MONGO_ROOT_PASSWORD=rootpassword
