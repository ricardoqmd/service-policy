# ─────────────────────────────────────────────────────────────────────────────
# Example environment variables for docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and customize for your local setup:
#
#   cp .env.example .env
#
# IMPORTANT:
#   - The `.env` file is gitignored: NEVER commit real secrets.
#   - This `.env.example` IS safe to commit: it contains only placeholders.
#   - All variables are optional. Docker Compose uses the defaults shown
#     below if a variable is missing or empty.
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# Host port mappings
# ═════════════════════════════════════════════════════════════════════════════
# Change these if you have other services using the same ports locally.
# Containers always listen on their default internal ports (8080, 27017, 8081);
# only the host-side mapping changes.
#
# Examples of when to change:
#   - You already have a MongoDB running on 27017 for another project.
#   - You're running two instances of this project in parallel.
#   - Port 8080 is taken by another local service.

SERVICE_POLICY_HOST_PORT=8080
MONGO_DB_HOST_PORT=27017
MONGO_EXPRESS_HOST_PORT=8081


# ═════════════════════════════════════════════════════════════════════════════
# MongoDB credentials
# ═════════════════════════════════════════════════════════════════════════════
# Used by both the mongodb service and mongo-express to authenticate.
# In production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
# instead of plain env vars.

MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpassword


# ═════════════════════════════════════════════════════════════════════════════
# Mongo Express UI authentication
# ═════════════════════════════════════════════════════════════════════════════
# Basic auth for the web UI. Override these for any shared environment.

MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin


# ═════════════════════════════════════════════════════════════════════════════
# Quarkus runtime configuration
# ═════════════════════════════════════════════════════════════════════════════
# Profile selection:
#   dev   → Swagger UI enabled, verbose logs, dev tooling active.
#   test  → Reduced logging, used by test suite.
#   prod  → Production-like behavior, Swagger UI disabled, JSON logs.

QUARKUS_PROFILE=dev

# Optional overrides (uncomment to use):
# QUARKUS_LOG_LEVEL=DEBUG
