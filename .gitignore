# ─── Secrets and local configuration ───────────────────────
# These files must NEVER be committed to the public repository.
# The pre-commit hook (gitleaks) validates that no secrets leak.
.env
.env.*
!.env.example
*.local.yml
*.local.yaml
*.local.properties
secrets/
**/secrets/**
*-secret.*
private/

# Specific credential file patterns that commonly leak
**/credentials.json
**/service-account*.json
**/*.pem
**/*.key
!**/sample*.pem
!**/sample*.key

# ─── Coverage and reports ──────────────────────────────────
*.exec
jacoco.exec
coverage/
.scannerwork/
